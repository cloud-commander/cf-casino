{
  "name": "cf-casino",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "concurrently -n \"BACKEND,FRONTEND\" -c \"magenta,cyan\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "wrangler dev",
    "dev:frontend": "npm run dev --prefix frontend",
    "deploy:dev": "wrangler deploy --env=\"\"",
    "deploy:prod": "wrangler deploy --env production",
    "build:frontend": "cd frontend && npm run build",
    "deploy:frontend": "npx wrangler pages deploy frontend/dist --project-name cf-casino-frontend",
    "db:migrate:dev": "wrangler d1 migrations apply cf-casino-db-at-dev --local",
    "db:migrate:prod": "wrangler d1 migrations apply cf-casino-db-at-prod --remote --env production",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloud-commander/cf-casino.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/cloud-commander/cf-casino/issues"
  },
  "homepage": "https://github.com/cloud-commander/cf-casino#readme",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260304.0",
    "@types/node": "^25.3.1",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.68.1"
  },
  "dependencies": {
    "jose": "^6.1.3",
    "zod": "^4.3.6"
  }
}
